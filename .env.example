# host port for Postgres (change if a local Postgres already uses 5432)
POSTGRES_HOST_PORT=5432
POSTGRES_PASSWORD=avalon_dev_password
POSTGRES_DB=avalon
GRAFANA_USER=admin
GRAFANA_PASSWORD=avalon_grafana
