{
  "uid": "avalon-data-ml-ops",
  "title": "Avalon Data & ML Ops",
  "tags": ["avalon", "pipeline", "ml"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Pipeline — BLOC 3 (avalon_elt every 15 min)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Minutes since last ELT run",
      "description": "Heartbeat: red means the Airflow DAG stopped landing runs",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - max(finished_at))) / 60.0 AS minutes FROM ops.pipeline_runs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 35 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fact rows (latest run)",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT fact_rows FROM ops.pipeline_runs ORDER BY finished_at DESC LIMIT 1"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DLQ messages (total)",
      "description": "Rejected events kept in avalon.enrollments.dlq — growth rate matters, not the absolute number",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "refId": "A", "expr": "sum(kafka_topic_partition_current_offset{topic=\"avalon.enrollments.dlq\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Consumer lag",
      "description": "Messages waiting for the warehouse loader group — sustained growth means the consumer fell behind",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "refId": "A", "expr": "sum(kafka_consumergroup_lag{consumergroup=\"avalon-warehouse-loader\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 5000 }
          ] }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Events streamed (landed)",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT stream_events FROM ops.pipeline_runs ORDER BY finished_at DESC LIMIT 1"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Warehouse fact rows per ELT run",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT finished_at AS time, fact_rows AS \"fact rows\" FROM ops.pipeline_runs WHERE $__timeFilter(finished_at) ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10, "spanNulls": true } },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Stream share of the fact table",
      "description": "Share of enrollments that arrived via Kafka rather than the historical seed",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT finished_at AS time, stream_share AS \"stream share\" FROM ops.pipeline_runs WHERE $__timeFilter(finished_at) ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "custom": { "fillOpacity": 10, "spanNulls": true } },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "ML — BLOC 4 (course recommender)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Recommendation requests by strategy (15 min)",
      "description": "A rising popularity-fallback share is an early drift alarm: the model knows fewer of the students it serves",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy) (increase(avalon_reco_requests_total[15m]))",
          "legendFormat": "{{strategy}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15, "spanNulls": true } },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "p95 serving latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(avalon_reco_latency_seconds_bucket[15m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.5 }
          ] },
          "noValue": "no traffic in window"
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Model in production (trained at)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "refId": "A", "expr": "avalon_reco_model_loaded == 1", "legendFormat": "{{trained_at}}", "instant": true }
      ],
      "options": { "textMode": "name", "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Dataset drift (last check)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 19 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT CASE WHEN dataset_drift THEN 1 ELSE 0 END AS drift FROM ops.ml_drift ORDER BY checked_at DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NO DRIFT", "color": "green" }, "1": { "text": "DRIFT", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "never checked"
        },
        "overrides": []
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Drifted feature share (last check)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT drift_share FROM ops.ml_drift ORDER BY checked_at DESC LIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.4 },
            { "color": "red", "value": 0.7 }
          ] },
          "noValue": "never checked"
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Input drift share over time",
      "description": "Evidently: share of model input features whose distribution drifted vs the training reference",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 23 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P3FF97A018DF5B732" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT checked_at AS time, drift_share AS \"drift share\" FROM ops.ml_drift WHERE $__timeFilter(checked_at) ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "max": 1, "min": 0,
          "custom": { "fillOpacity": 10, "spanNulls": true, "drawStyle": "points", "pointSize": 8 }
        },
        "overrides": []
      }
    }
  ]
}
